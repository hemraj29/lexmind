generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── CASES (Central entity — each case IS a chat thread) ──

model Case {
  id            String     @id @default(cuid())
  title         String                          // "State vs. Rajesh Kumar" (auto-generated or user-set)
  caseNumber    String?    @map("case_number")  // Court case number if assigned
  clientName    String?    @map("client_name")
  court         String?
  district      String?
  state         String?
  status        CaseStatus @default(ACTIVE)
  summary       String?                          // AI-generated, updated on new docs
  sectionsRaw   String[]   @map("sections_raw")  // Aggregated from all docs
  tags          String[]   @default([])

  // Relations
  messages      ChatMessage[]
  documents     CaseDocument[]
  pipelineRuns  PipelineRun[]
  generatedDocs GeneratedDocument[]

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("cases")
}

// ─── CHAT MESSAGES (The chat IS the case history) ─────────

model ChatMessage {
  id            String      @id @default(cuid())
  caseId        String      @map("case_id")
  case          Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)

  role          MessageRole
  type          MessageType
  content       String       // Text content or card JSON

  // File attachment (if type = FILE_UPLOAD)
  documentId    String?      @map("document_id")
  document      CaseDocument? @relation(fields: [documentId], references: [id])

  // Generation run (if type = COMMAND that triggers generation)
  pipelineRunId String?      @map("pipeline_run_id")
  pipelineRun   PipelineRun? @relation(fields: [pipelineRunId], references: [id])

  // AI metadata (sources cited, sections referenced)
  metadata      Json?

  // Citations attached to this message
  citations     Citation[]

  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([caseId, createdAt])
  @@map("chat_messages")
}

// ─── CASE DOCUMENTS (Uploads linked to a case) ───────────

model CaseDocument {
  id            String           @id @default(cuid())
  caseId        String           @map("case_id")
  case          Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  docType       CaseDocumentType @map("doc_type")
  fileName      String           @map("file_name")
  mimeType      String           @map("mime_type")
  filePath      String           @map("file_path")
  fileSize      Int              @map("file_size")

  // AI-extracted structured data (JSONB — shape depends on docType)
  extractedData Json?            @map("extracted_data")
  rawText       String?          @map("raw_text")
  confidence    Float?

  // Whether the user has the source enabled in the chat context
  enabled       Boolean          @default(true)
  title         String?

  // Relations
  chatMessages  ChatMessage[]
  pipelineRuns  PipelineRun[]
  citations     Citation[]

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([caseId])
  @@index([docType])
  @@map("case_documents")
}

// ─── ACTS (Parent table for all legislation) ──────────────

model Act {
  id          String   @id @default(cuid())
  code        ActType  @unique
  fullName    String   @map("full_name")
  year        Int
  description String?
  replacedAct String?  @map("replaced_act")

  sections    StatuteSection[]
  chapters    Chapter[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("acts")
}

// ─── CHAPTERS ─────────────────────────────────────────────

model Chapter {
  id          String   @id @default(cuid())
  actId       String   @map("act_id")
  act         Act      @relation(fields: [actId], references: [id], onDelete: Cascade)
  number      Int
  title       String
  description String?

  sections    StatuteSection[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([actId, number])
  @@map("chapters")
}

// ─── STATUTE SECTIONS ─────────────────────────────────────

model StatuteSection {
  id            String      @id @default(cuid())
  actId         String      @map("act_id")
  act           Act         @relation(fields: [actId], references: [id], onDelete: Cascade)
  actType       ActType     @map("act_type")
  chapterId     String?     @map("chapter_id")
  chapter       Chapter?    @relation(fields: [chapterId], references: [id])
  sectionNumber String      @map("section_number")
  title         String
  description   String                          // Full legal text from the Act
  summary       String?                         // 2-3 line plain English summary
  offenceType   OffenceType @map("offence_type")
  bailable      Boolean
  compoundable  Boolean     @default(false)
  punishment    String
  minPunishment String?     @map("min_punishment")
  maxPunishment String?     @map("max_punishment")
  ingredients   String[]
  keywords      String[]
  exceptions    String[]    @default([])
  explanation   String?

  // Source traceability (used by citation preview UI)
  pageNumber       Int?     @map("page_number")
  sourceFile       String?  @map("source_file")
  sourceReference  String?  @map("source_reference")

  ipcMappingsAsBNS IPCMapping[]  @relation("BNSSection")
  precedentLinks   PrecedentSection[]
  citations        Citation[]
  outgoingRelations SectionRelation[] @relation("FromSection")
  incomingRelations SectionRelation[] @relation("ToSection")

  embedding     Unsupported("vector(1536)")?

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([actType, sectionNumber])
  @@index([actType])
  @@index([bailable])
  @@index([sectionNumber])
  @@index([actId])
  @@map("statute_sections")
}

// ─── IPC TO BNS MAPPING ──────────────────────────────────

model IPCMapping {
  id              String            @id @default(cuid())
  ipcSection      String            @unique @map("ipc_section")
  ipcTitle        String            @map("ipc_title")
  bnsSection      String            @map("bns_section")
  bnsTitle        String            @map("bns_title")
  bnsSectionId    String?           @map("bns_section_id")
  bnsSectionRef   StatuteSection?   @relation("BNSSection", fields: [bnsSectionId], references: [id])
  changeType      MappingChangeType @default(RENAMED) @map("change_type")
  notes           String?

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([bnsSection])
  @@map("ipc_mappings")
}

// ─── CASE PRECEDENTS ──────────────────────────────────────

model Precedent {
  id               String   @id @default(cuid())
  caseTitle        String   @map("case_title")
  citation         String   @unique
  court            String
  bench            String?
  year             Int
  ratio            String
  summary          String
  headnotes        String?
  tags             String[]
  bailRelevant     Boolean  @default(false) @map("bail_relevant")

  sectionLinks     PrecedentSection[]
  citations        Citation[]

  embedding        Unsupported("vector(1536)")?

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([court])
  @@index([year])
  @@index([bailRelevant])
  @@map("precedents")
}

// ─── JOIN TABLE: Precedent <-> StatuteSection ─────────────

model PrecedentSection {
  id          String         @id @default(cuid())
  precedentId String         @map("precedent_id")
  precedent   Precedent      @relation(fields: [precedentId], references: [id], onDelete: Cascade)
  sectionId   String         @map("section_id")
  section     StatuteSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  relevance   String?

  @@unique([precedentId, sectionId])
  @@map("precedent_sections")
}

// ─── PIPELINE RUNS ────────────────────────────────────────

model PipelineRun {
  id              String             @id @default(cuid())
  caseId          String?            @map("case_id")
  case            Case?              @relation(fields: [caseId], references: [id])
  documentId      String?            @map("document_id")
  document        CaseDocument?      @relation(fields: [documentId], references: [id])
  generationType  GenerationDocType? @map("generation_type")

  status          RunStatus          @default(PENDING)
  fileName        String             @map("file_name")
  mimeType        String             @map("mime_type")
  uploadPath      String             @map("upload_path")

  // Extracted data (JSONB — shape depends on doc type)
  extractedData   Json?              @map("extracted_data")

  // Legal research memo (JSONB)
  legalMemo       Json?              @map("legal_memo")

  // Draft output
  draftMarkdown   String?            @map("draft_markdown")
  docxPath        String?            @map("docx_path")

  // Pipeline tracking
  steps           Json[]             @default([])
  currentStep     String?            @map("current_step")
  totalDurationMs Int?               @map("total_duration_ms")
  error           String?

  // Relations
  documents       GeneratedDocument[]
  chatMessages    ChatMessage[]
  citations       Citation[]

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([status])
  @@index([caseId])
  @@index([createdAt(sort: Desc)])
  @@map("pipeline_runs")
}

// ─── GENERATED DOCUMENTS ──────────────────────────────────

model GeneratedDocument {
  id            String            @id @default(cuid())
  pipelineRunId String            @map("pipeline_run_id")
  pipelineRun   PipelineRun       @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  caseId        String?           @map("case_id")
  case          Case?             @relation(fields: [caseId], references: [id])
  docType       GenerationDocType @map("doc_type")
  filePath      String            @map("file_path")
  fileSize      Int               @map("file_size")
  mimeType      String            @map("mime_type")

  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([caseId])
  @@map("generated_documents")
}

// ─── ENUMS ────────────────────────────────────────────────

enum ActType {
  BNS
  BNSS
  BSA
}

enum OffenceType {
  COGNIZABLE     @map("cognizable")
  NON_COGNIZABLE @map("non-cognizable")
}

enum RunStatus {
  PENDING   @map("pending")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
}

enum MappingChangeType {
  RENAMED     @map("renamed")
  MODIFIED    @map("modified")
  MERGED      @map("merged")
  SPLIT       @map("split")
  NEW         @map("new")
  REPEALED    @map("repealed")
}

enum CaseStatus {
  ACTIVE   @map("active")
  CLOSED   @map("closed")
  ARCHIVED @map("archived")
}

enum CaseDocumentType {
  FIR                @map("fir")
  CHARGESHEET        @map("chargesheet")
  COURT_ORDER        @map("court_order")
  WITNESS_STATEMENT  @map("witness_statement")
  EVIDENCE           @map("evidence")
  PREVIOUS_PETITION  @map("previous_petition")
  OTHER              @map("other")
}

enum GenerationDocType {
  // Criminal
  REGULAR_BAIL          @map("regular_bail")
  ANTICIPATORY_BAIL     @map("anticipatory_bail")
  DEFAULT_BAIL          @map("default_bail")
  QUASHING_PETITION     @map("quashing_petition")
  DISCHARGE_APPLICATION @map("discharge_application")
  CRIMINAL_APPEAL       @map("criminal_appeal")
  // Civil
  PLAINT                @map("plaint")
  WRITTEN_STATEMENT     @map("written_statement")
  TEMPORARY_INJUNCTION  @map("temporary_injunction")
  // Generic
  LEGAL_MEMO            @map("legal_memo")
  OTHER                 @map("other")
}

// ═══════════════════════════════════════════════════════════════════════
//  PLUGIN ARCHITECTURE — domain/act/document type registry (DB-driven)
//  These tables make adding new Acts/domains a config change, not code.
// ═══════════════════════════════════════════════════════════════════════

model LegalDomain {
  id            String   @id @default(cuid())
  code          String   @unique           // "criminal", "civil", "tax", "family"
  name          String                     // "Criminal Law"
  description   String?
  iconName      String?  @map("icon_name")
  colorHex      String?  @map("color_hex")
  sortOrder     Int      @default(0) @map("sort_order")
  enabled       Boolean  @default(true)

  documentTypes RegisteredDocumentType[]
  studioActions StudioAction[]
  chatCommands  ChatCommand[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("legal_domains")
}

model RegisteredDocumentType {
  id                  String       @id @default(cuid())
  code                String       @unique  // "regular_bail", "plaint", "moa"
  name                String
  description         String?

  domainId            String       @map("domain_id")
  domain              LegalDomain  @relation(fields: [domainId], references: [id], onDelete: Cascade)

  category            String       @default("draft")  // "draft" | "analyze" | "research" | "extract"
  iconName            String?      @map("icon_name")
  colorHex            String?      @map("color_hex")

  requiredSourceTypes String[]     @default([]) @map("required_source_types")
  primarySectionCodes String[]     @default([]) @map("primary_section_codes")
  drafterPluginId     String?      @map("drafter_plugin_id")
  templateConfig      Json         @default("{}") @map("template_config")

  command             String?      @unique  // "@bail"
  enabled             Boolean      @default(true)
  sortOrder           Int          @default(0) @map("sort_order")
  usageCount          Int          @default(0) @map("usage_count")

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([domainId])
  @@map("registered_document_types")
}

model StudioAction {
  id                  String       @id @default(cuid())
  code                String       @unique
  label               String
  description         String?
  iconName            String       @map("icon_name")
  colorHex            String?      @map("color_hex")
  category            String       @default("draft")
  command             String?

  domainId            String       @map("domain_id")
  domain              LegalDomain  @relation(fields: [domainId], references: [id], onDelete: Cascade)

  requiredSourceTypes String[]     @default([]) @map("required_source_types")
  enabled             Boolean      @default(true)
  sortOrder           Int          @default(0) @map("sort_order")

  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([domainId])
  @@map("studio_actions")
}

model ChatCommand {
  id            String       @id @default(cuid())
  cmd           String       @unique  // "@bail"
  label         String
  description   String
  color         String?

  domainId      String?      @map("domain_id")
  domain        LegalDomain? @relation(fields: [domainId], references: [id], onDelete: SetNull)

  documentTypeCode String?    @map("document_type_code")
  enabled       Boolean      @default(true)
  sortOrder     Int          @default(0) @map("sort_order")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("chat_commands")
}

// ═══════════════════════════════════════════════════════════════════════
//  CITATION SYSTEM — every claim → traceable source
// ═══════════════════════════════════════════════════════════════════════

model Citation {
  id            String              @id @default(cuid())

  messageId     String?             @map("message_id")
  message       ChatMessage?        @relation(fields: [messageId], references: [id], onDelete: Cascade)

  pipelineRunId String?             @map("pipeline_run_id")
  pipelineRun   PipelineRun?        @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  sourceType    CitationSourceType  @map("source_type")

  // For statute sections
  sectionId     String?             @map("section_id")
  section       StatuteSection?     @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  pageNumber    Int?                @map("page_number")
  paragraphRef  String?             @map("paragraph_ref")

  // For precedents
  precedentId   String?             @map("precedent_id")
  precedent     Precedent?          @relation(fields: [precedentId], references: [id], onDelete: SetNull)
  sccReference  String?             @map("scc_reference")
  passageStart  Int?                @map("passage_start")
  passageEnd    Int?                @map("passage_end")

  // For uploaded documents
  documentId    String?             @map("document_id")
  document      CaseDocument?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  documentPage  Int?                @map("document_page")

  // For web sources
  webUrl        String?             @map("web_url")
  webTitle      String?             @map("web_title")

  excerptText   String              @map("excerpt_text")
  fullSourceUrl String?             @map("full_source_url")

  createdAt     DateTime            @default(now()) @map("created_at")

  @@index([messageId])
  @@index([sectionId])
  @@index([precedentId])
  @@index([documentId])
  @@map("citations")
}

enum CitationSourceType {
  SECTION    @map("section")
  PRECEDENT  @map("precedent")
  DOCUMENT   @map("document")
  WEB        @map("web")
}

// ═══════════════════════════════════════════════════════════════════════
//  KNOWLEDGE GRAPH — section relationships
// ═══════════════════════════════════════════════════════════════════════

model SectionRelation {
  id            String         @id @default(cuid())
  fromSectionId String         @map("from_section_id")
  fromSection   StatuteSection @relation("FromSection", fields: [fromSectionId], references: [id], onDelete: Cascade)
  toSectionId   String         @map("to_section_id")
  toSection     StatuteSection @relation("ToSection", fields: [toSectionId], references: [id], onDelete: Cascade)
  relationType  String         @map("relation_type")  // "punishes", "exception_to", "variant_of", etc.
  confidence    Float          @default(1.0)
  notes         String?

  createdAt     DateTime       @default(now()) @map("created_at")

  @@unique([fromSectionId, toSectionId, relationType])
  @@index([fromSectionId])
  @@index([toSectionId])
  @@map("section_relations")
}

// ═══════════════════════════════════════════════════════════════════════
//  CACHED EXTERNAL SEARCH RESULTS (Indian Kanoon, SCC, etc.)
// ═══════════════════════════════════════════════════════════════════════

model CitationCache {
  id           String   @id @default(cuid())
  queryHash    String   @unique @map("query_hash")
  providerId   String   @map("provider_id")
  candidates   Json
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([providerId])
  @@index([expiresAt])
  @@map("citation_cache")
}

enum MessageRole {
  USER       @map("user")
  ASSISTANT  @map("assistant")
  SYSTEM     @map("system")
}

enum MessageType {
  TEXT             @map("text")
  FILE_UPLOAD      @map("file_upload")
  COMMAND          @map("command")
  ANALYSIS_CARD    @map("analysis_card")
  GENERATION_CARD  @map("generation_card")
}
